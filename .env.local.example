APP_ENV=local
ENV_FILE=.env.local

# Database (local)
MYSQL_PASSWORD=change_me
SQLALCHEMY_DATABASE_URI=mysql+mysqlconnector://admin:${MYSQL_PASSWORD}@localhost:3306/worksmart

# Auth
SECRET_KEY=replace_with_at_least_32_characters
BCRYPT_LOG_ROUNDS=12

# Storage
IMG_FOLDER=/absolute/path/to/bills
OUTBOUND_FOLDER=/absolute/path/to/outbound

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Runtime
PORT=8080
WEB_CONCURRENCY=2

# CORS
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Observability
LOG_LEVEL=INFO
