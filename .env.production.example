APP_ENV=production
ENV_FILE=.env.production

# Database (production)
# Use full URI provided by your DB provider
SQLALCHEMY_DATABASE_URI=mysql+mysqlconnector://<user>:<password>@<host>:3306/<db_name>
MYSQL_PASSWORD=

# Auth
SECRET_KEY=replace_with_at_least_32_characters
BCRYPT_LOG_ROUNDS=12

# Storage (kept for backward compatibility)
IMG_FOLDER=/tmp/bills
OUTBOUND_FOLDER=/tmp/outbound

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Runtime
PORT=10000
WEB_CONCURRENCY=2

# CORS
CORS_ORIGINS=https://your-frontend.onrender.com

# Observability
LOG_LEVEL=INFO
