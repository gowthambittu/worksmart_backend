# Database
MYSQL_PASSWORD=change_me
SQLALCHEMY_DATABASE_URI=mysql+pymysql://admin:${MYSQL_PASSWORD}@localhost/worksmart

# Auth
SECRET_KEY=replace_with_at_least_32_characters
BCRYPT_LOG_ROUNDS=12

# Storage
